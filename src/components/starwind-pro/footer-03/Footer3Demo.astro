---
import IconBrandGithub from "@tabler/icons/filled/brand-github.svg";
import IconBrandLinkedin from "@tabler/icons/filled/brand-linkedin.svg";
import IconBrandDiscord from "@tabler/icons/filled/brand-discord.svg";
import IconBrandFacebook from "@tabler/icons/filled/brand-facebook.svg";
import IconBrandInstagram from "@tabler/icons/filled/brand-instagram.svg";
import IconBrandYoutube from "@tabler/icons/filled/brand-youtube.svg";
import IconBrandX from "@tabler/icons/outline/brand-x.svg";
import IconLogo from "@tabler/icons/outline/mood-wink.svg";

import Footer3, { type FooterColumn, type SocialLink } from "./Footer3.astro";

const columns: FooterColumn[] = [
  {
    title: "Platform",
    links: [
      { label: "Home", href: "/" },
      { label: "Hotels", href: "/hotels/" },
      { label: "Partners", href: "/partners/" },
      { label: "Products", href: "/products/" },
      { label: "Pricing", href: "/pricing/" },
    ],
  },
  {
    title: "Product stack",
    links: [
      { label: "Extranet", href: "/products/extranet/" },
      { label: "Studio", href: "/products/studio/" },
      { label: "WinkSocial", href: "/products/winksocial/" },
      { label: "WinkLinks", href: "/products/winklinks/" },
      { label: "Booking Engine", href: "/products/booking-engine/" },
    ],
  },
  {
    title: "Resources",
    links: [
      { label: "Resource hub", href: "/resources/" },
      { label: "Academy", href: "/academy/" },
      { label: "Developers", href: "/developers/" },
      { label: "Docs", href: "/developers/docs/" },
      { label: "Contact", href: "/contact/" },
    ],
  },
  {
    title: "Company",
    links: [
      { label: "About", href: "/about/" },
      { label: "Press", href: "/press/" },
      { label: "Careers", href: "/careers/" },
      { label: "Login", href: "/login/" },
      { label: "Sign up", href: "/signup/" },
    ],
  },
];

const socialLinks: SocialLink[] = [
  { icon: IconBrandGithub, name: "Github", href: "https://github.com/wink-travel" },
  { icon: IconBrandX, name: "X", href: "https://x.com/wink2travel" },
  { icon: IconBrandDiscord, name: "Discord", href: "https://discord.gg/t3YETu8k5n" },
  { icon: IconBrandFacebook, name: "Facebook", href: "https://facebook.com/wink2travel" },
  { icon: IconBrandLinkedin, name: "LinkedIn", href: "https://linkedin.com/company/wink2travel" },
  { icon: IconBrandInstagram, name: "Instagram", href: "https://instagram.com/wink2travel" },
  { icon: IconBrandYoutube, name: "YouTube", href: "https://www.youtube.com/@wink2travel" },
];
---

<Footer3 companyName="Wink" description="Create demand. Convert bookings. Keep the guest." logoIcon={IconLogo} columns={columns} socialLinks={socialLinks} />
