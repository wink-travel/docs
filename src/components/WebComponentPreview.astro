---
interface Props {
  src: string;
  minWidth?: number;
  height?: number;
}

const { src, minWidth = 375, height = 800 } = Astro.props;
---

<div
  class="wcp-root"
  data-src={src}
  data-min-width={minWidth}
  data-height={height}
>
  <!-- Toolbar: device presets + width badge -->
  <div class="wcp-toolbar">
    <div class="wcp-presets">
      <button type="button" class="wcp-preset" data-preset="mobile" data-width="375" title="Mobile (375px)">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 384 512" fill="currentColor">
          <path d="M16 64C16 28.7 44.7 0 80 0H304c35.3 0 64 28.7 64 64V448c0 35.3-28.7 64-64 64H80c-35.3 0-64-28.7-64-64V64zM224 448a32 32 0 1 0 -64 0 32 32 0 1 0 64 0zM304 64H80V384H304V64z"/>
        </svg>
      </button>
      <button type="button" class="wcp-preset" data-preset="tablet" data-width="768" title="Tablet (768px)">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 448 512" fill="currentColor">
          <path d="M0 64C0 28.7 28.7 0 64 0H384c35.3 0 64 28.7 64 64V448c0 35.3-28.7 64-64 64H64c-35.3 0-64-28.7-64-64V64zM256 448a32 32 0 1 0 -64 0 32 32 0 1 0 64 0zM384 64H64V384H384V64z"/>
        </svg>
      </button>
      <button type="button" class="wcp-preset" data-preset="desktop" data-width="1024" title="Desktop (1024px)">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 576 512" fill="currentColor">
          <path d="M64 0C28.7 0 0 28.7 0 64V352c0 35.3 28.7 64 64 64H240l-10.7 32H160c-17.7 0-32 14.3-32 32s14.3 32 32 32H416c17.7 0 32-14.3 32-32s-14.3-32-32-32H346.7L336 416H512c35.3 0 64-28.7 64-64V64c0-35.3-28.7-64-64-64H64zM512 64V352H64V64H512z"/>
        </svg>
      </button>
      <button type="button" class="wcp-preset wcp-preset--active" data-preset="full" title="Full width">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 512 512" fill="currentColor">
          <path d="M344 0H488c13.3 0 24 10.7 24 24V168c0 9.7-5.8 18.5-14.8 22.2s-19.3 1.7-26.2-5.2l-39-39-87 87c-9.4 9.4-24.6 9.4-33.9 0l-24-24c-9.4-9.4-9.4-24.6 0-33.9l87-87L335 48.8c-6.9-6.9-8.9-17.2-5.2-26.2S334.3 0 344 0zM168 512H24c-13.3 0-24-10.7-24-24V344c0-9.7 5.8-18.5 14.8-22.2s19.3-1.7 26.2 5.2l39 39 87-87c9.4-9.4 24.6-9.4 33.9 0l24 24c9.4 9.4 9.4 24.6 0 33.9l-87 87 39.2 39c6.9 6.9 8.9 17.2 5.2 26.2S177.7 512 168 512z"/>
        </svg>
      </button>
    </div>
    <span class="wcp-width-badge"></span>
  </div>

  <!-- Theme editor (collapsible) -->
  <details class="wcp-theme-details">
    <summary class="wcp-theme-toggle">Theme</summary>
    <div class="wcp-theme-panel">
      <div class="wcp-theme-row">
        <label class="wcp-theme-label">
          Palette
          <select class="wcp-palette-select"></select>
        </label>
        <button type="button" class="wcp-reset-btn">Reset</button>
      </div>
      <div class="wcp-color-grid">
        <label class="wcp-color-field">
          <span>primary</span>
          <input type="color" data-color-key="primary" />
        </label>
        <label class="wcp-color-field">
          <span>secondary</span>
          <input type="color" data-color-key="secondary" />
        </label>
        <label class="wcp-color-field">
          <span>success</span>
          <input type="color" data-color-key="success" />
        </label>
        <label class="wcp-color-field">
          <span>info</span>
          <input type="color" data-color-key="info" />
        </label>
        <label class="wcp-color-field">
          <span>danger</span>
          <input type="color" data-color-key="danger" />
        </label>
        <label class="wcp-color-field">
          <span>warning</span>
          <input type="color" data-color-key="warning" />
        </label>
        <label class="wcp-color-field">
          <span>light</span>
          <input type="color" data-color-key="light" />
        </label>
        <label class="wcp-color-field">
          <span>dark</span>
          <input type="color" data-color-key="dark" />
        </label>
        <label class="wcp-color-field">
          <span>body</span>
          <input type="color" data-color-key="body" />
        </label>
        <label class="wcp-color-field">
          <span>muted</span>
          <input type="color" data-color-key="muted" />
        </label>
        <label class="wcp-color-field">
          <span>white</span>
          <input type="color" data-color-key="white" />
        </label>
      </div>
    </div>
  </details>

  <!-- Preview area: iframe + drag handle -->
  <div class="wcp-preview">
    <iframe
      class="wcp-iframe"
      title="Web component preview"
      aria-label="Web component preview"
      loading="lazy"
    ></iframe>
    <div class="wcp-drag-handle" title="Drag to resize">
      <div class="wcp-drag-pill"></div>
    </div>
  </div>
</div>

<style>
  .wcp-root {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin: 1.5rem 0;
  }

  .wcp-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-radius: 1rem;
    background: var(--sl-color-gray-6, #f4f5f7);
    padding: 0.5rem 1rem;
    border: 1px solid var(--sl-color-gray-5, #e0e2e6);
  }

  :global([data-theme='dark']) .wcp-toolbar {
    background: var(--sl-color-gray-6, #23262f);
    border-color: var(--sl-color-gray-5, #343841);
  }

  .wcp-presets {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .wcp-preset {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
    border-radius: 0.5rem;
    border: none;
    background: transparent;
    color: var(--sl-color-gray-3, #6b7280);
    cursor: pointer;
    transition: color 0.15s, background 0.15s;
  }

  .wcp-preset:hover {
    color: var(--sl-color-white, #111);
  }

  :global([data-theme='dark']) .wcp-preset:hover {
    color: var(--sl-color-white, #fff);
  }

  .wcp-preset--active {
    background: var(--sl-color-accent, #3b82f6);
    background: color-mix(in srgb, var(--sl-color-accent, #3b82f6) 15%, transparent);
    color: var(--sl-color-accent, #3b82f6);
  }

  .wcp-width-badge {
    font-size: 0.75rem;
    font-weight: 500;
    font-variant-numeric: tabular-nums;
    color: var(--sl-color-gray-3, #6b7280);
  }

  /* Theme editor */
  .wcp-theme-details {
    border-radius: 1rem;
    border: 1px solid var(--sl-color-gray-5, #e0e2e6);
    overflow: hidden;
  }

  :global([data-theme='dark']) .wcp-theme-details {
    border-color: var(--sl-color-gray-5, #343841);
  }

  .wcp-theme-toggle {
    cursor: pointer;
    padding: 0.5rem 1rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--sl-color-gray-2, #444);
    background: var(--sl-color-gray-6, #f4f5f7);
    user-select: none;
    list-style: none;
  }

  :global([data-theme='dark']) .wcp-theme-toggle {
    background: var(--sl-color-gray-6, #23262f);
    color: var(--sl-color-gray-2, #c0c4cc);
  }

  .wcp-theme-toggle::-webkit-details-marker { display: none; }
  .wcp-theme-toggle::marker { content: ''; }

  .wcp-theme-toggle::before {
    content: '▸ ';
  }

  .wcp-theme-details[open] .wcp-theme-toggle::before {
    content: '▾ ';
  }

  .wcp-theme-panel {
    padding: 0.75rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .wcp-theme-row {
    display: flex;
    align-items: end;
    gap: 0.75rem;
  }

  .wcp-theme-label {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--sl-color-gray-2, #444);
    flex: 1;
  }

  :global([data-theme='dark']) .wcp-theme-label {
    color: var(--sl-color-gray-2, #c0c4cc);
  }

  .wcp-palette-select {
    padding: 0.375rem 0.5rem;
    border-radius: 0.375rem;
    border: 1px solid var(--sl-color-gray-5, #d1d5db);
    font-size: 0.8125rem;
    background: var(--sl-color-white, #fff);
    color: inherit;
  }

  :global([data-theme='dark']) .wcp-palette-select {
    background: var(--sl-color-gray-6, #23262f);
    border-color: var(--sl-color-gray-5, #343841);
  }

  .wcp-reset-btn {
    padding: 0.375rem 0.75rem;
    border-radius: 0.375rem;
    border: 1px solid var(--sl-color-gray-5, #d1d5db);
    background: transparent;
    font-size: 0.8125rem;
    cursor: pointer;
    color: var(--sl-color-gray-2, #444);
    white-space: nowrap;
  }

  :global([data-theme='dark']) .wcp-reset-btn {
    border-color: var(--sl-color-gray-5, #343841);
    color: var(--sl-color-gray-2, #c0c4cc);
  }

  .wcp-color-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
  }

  .wcp-color-field {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    color: var(--sl-color-gray-2, #555);
    cursor: pointer;
  }

  :global([data-theme='dark']) .wcp-color-field {
    color: var(--sl-color-gray-2, #c0c4cc);
  }

  .wcp-color-field input[type="color"] {
    width: 1.5rem;
    height: 1.5rem;
    border: 1px solid var(--sl-color-gray-5, #d1d5db);
    border-radius: 0.25rem;
    padding: 1px;
    cursor: pointer;
    background: none;
  }

  /* Preview area */
  .wcp-preview {
    position: relative;
    transition: max-width 0.3s ease, width 0.3s ease;
  }

  .wcp-preview--dragging {
    transition: none;
  }

  .wcp-iframe {
    width: 100%;
    overflow: hidden;
    border-radius: 1rem;
    border: 1px solid var(--sl-color-gray-5, #e0e2e6);
    display: block;
    background: #fff;
  }

  :global([data-theme='dark']) .wcp-iframe {
    border-color: var(--sl-color-gray-5, #343841);
  }

  .wcp-drag-handle {
    position: absolute;
    inset-block: 0;
    left: 100%;
    display: none;
    align-items: center;
    padding: 0 0.5rem;
    cursor: ew-resize;
  }

  @media (min-width: 640px) {
    .wcp-drag-handle { display: flex; }
  }

  .wcp-drag-pill {
    width: 0.375rem;
    height: 2rem;
    border-radius: 9999px;
    background: var(--sl-color-gray-4, #c5c8ce);
    transition: background 0.15s;
  }

  .wcp-drag-pill:hover {
    background: var(--sl-color-gray-3, #9ca3af);
  }
</style>

<script>
  import { COLOR_PALETTES, COLOR_KEYS, type ColorKey } from '../data/color-palettes';

  class WebComponentPreviewHandler {
    private root: HTMLElement;
    private iframe: HTMLIFrameElement;
    private preview: HTMLElement;
    private widthBadge: HTMLElement;
    private presetButtons: NodeListOf<HTMLElement>;
    private colorInputs: NodeListOf<HTMLInputElement>;
    private paletteSelect: HTMLSelectElement;
    private resetBtn: HTMLElement;
    private dragHandle: HTMLElement;

    private baseSrc: string;
    private minWidth: number;
    private height: number;
    private dragging = false;
    private activePalette: typeof COLOR_PALETTES[number];
    private currentColors: Record<ColorKey, string>;
    private updateTimer: ReturnType<typeof setTimeout> | null = null;

    constructor(root: HTMLElement) {
      this.root = root;
      this.iframe = root.querySelector('.wcp-iframe')!;
      this.preview = root.querySelector('.wcp-preview')!;
      this.widthBadge = root.querySelector('.wcp-width-badge')!;
      this.presetButtons = root.querySelectorAll('.wcp-preset');
      this.colorInputs = root.querySelectorAll('input[data-color-key]');
      this.paletteSelect = root.querySelector('.wcp-palette-select')!;
      this.resetBtn = root.querySelector('.wcp-reset-btn')!;
      this.dragHandle = root.querySelector('.wcp-drag-handle')!;

      this.baseSrc = root.dataset.src || '/demos/hotel-card';
      this.minWidth = parseInt(root.dataset.minWidth || '375', 10);
      this.height = parseInt(root.dataset.height || '800', 10);

      this.activePalette = COLOR_PALETTES[0];
      this.currentColors = { ...this.activePalette.palette };

      this.init();
    }

    private init(): void {
      this.iframe.style.height = `${this.height}px`;
      this.iframe.style.minWidth = `${this.minWidth}px`;

      this.populatePalettes();
      this.applyColorsToInputs();
      this.setWidth(this.computeAvailableWidth());
      this.updateIframeSrc();

      // Device presets
      for (const btn of this.presetButtons) {
        btn.addEventListener('click', () => {
          const widthAttr = btn.dataset.width;
          if (widthAttr) {
            this.setWidth(Math.max(parseInt(widthAttr, 10), this.minWidth));
          } else {
            this.setWidth(this.computeAvailableWidth());
          }
          this.setActivePreset(btn.dataset.preset || '');
        });
      }

      // Drag handle
      this.dragHandle.addEventListener('mousedown', (e: MouseEvent) => {
        e.preventDefault();
        this.dragging = true;
        this.preview.classList.add('wcp-preview--dragging');
        this.setActivePreset('');
      });
      document.addEventListener('mousemove', (e: MouseEvent) => this.onDrag(e));
      document.addEventListener('mouseup', () => {
        if (this.dragging) {
          this.dragging = false;
          this.preview.classList.remove('wcp-preview--dragging');
        }
      });

      // Color inputs
      for (const input of this.colorInputs) {
        input.addEventListener('input', () => {
          const key = input.dataset.colorKey as ColorKey;
          this.currentColors = { ...this.currentColors, [key]: input.value };
          this.scheduleIframeUpdate();
        });
      }

      // Palette select
      this.paletteSelect.addEventListener('change', () => {
        const palette = COLOR_PALETTES.find(p => p.name === this.paletteSelect.value);
        if (palette) {
          this.activePalette = palette;
          this.currentColors = { ...palette.palette };
          this.applyColorsToInputs();
          this.updateIframeSrc();
        }
      });

      // Reset
      this.resetBtn.addEventListener('click', () => {
        this.currentColors = { ...this.activePalette.palette };
        this.applyColorsToInputs();
        this.updateIframeSrc();
      });
    }

    private populatePalettes(): void {
      for (const palette of COLOR_PALETTES) {
        const option = document.createElement('option');
        option.value = palette.name;
        option.textContent = palette.name.replace(/_/g, ' ');
        this.paletteSelect.appendChild(option);
      }
    }

    private applyColorsToInputs(): void {
      for (const input of this.colorInputs) {
        const key = input.dataset.colorKey as ColorKey;
        input.value = this.currentColors[key];
      }
    }

    private setWidth(width: number): void {
      this.preview.style.maxWidth = `${width}px`;
      this.preview.style.width = `${width}px`;
      this.widthBadge.textContent = `${width}px`;
    }

    private setActivePreset(id: string): void {
      for (const btn of this.presetButtons) {
        btn.classList.toggle('wcp-preset--active', btn.dataset.preset === id);
      }
    }

    private computeAvailableWidth(): number {
      return this.root.clientWidth;
    }

    private onDrag(e: MouseEvent): void {
      if (!this.dragging) return;
      const rect = this.preview.getBoundingClientRect();
      const newWidth = e.clientX - rect.left;
      this.setWidth(Math.max(newWidth, this.minWidth));
    }

    private buildIframeSrc(): string {
      const params = new URLSearchParams();
      for (const key of COLOR_KEYS) {
        params.set(key, this.currentColors[key].replace('#', ''));
      }
      return `${this.baseSrc}?${params.toString()}`;
    }

    private updateIframeSrc(): void {
      this.iframe.src = this.buildIframeSrc();
    }

    private scheduleIframeUpdate(): void {
      if (this.updateTimer) clearTimeout(this.updateTimer);
      this.updateTimer = setTimeout(() => this.updateIframeSrc(), 200);
    }
  }

  function initAll() {
    for (const root of document.querySelectorAll<HTMLElement>('.wcp-root')) {
      new WebComponentPreviewHandler(root);
    }
  }

  // Starlight uses View Transitions — re-init on page swap
  document.addEventListener('astro:page-load', initAll);
  initAll();
</script>
